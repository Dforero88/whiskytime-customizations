<div class="wtholidays wtholidays--product">
  <div class="wtholidays__card wtholidays__card--compact" style="padding:0;border:0;border-radius:0;background:transparent;box-shadow:none;">
    <p class="wtholidays__message wtholidays__message--product" style="display:inline-flex;align-items:flex-start;gap:8px;margin:0;color:#b22222;font-size:15px;line-height:1.5;font-style:italic;">
      <span class="wtholidays__icon material-icons" aria-hidden="true" style="flex:0 0 auto;margin-top:2px;color:#b22222;font-size:16px;line-height:1;">event_busy</span>
      <span class="wtholidays__message-copy" style="color:#b22222;">{$wtholidays.message|escape:'html':'UTF-8'|nl2br nofilter}</span>
    </p>
  </div>
</div>
